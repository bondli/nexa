{
  "$schema":"https://json.schemastore.org/claude-code-settings.json",
  "permissions":{
    "allow":[
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Read",
      "Write",
      "Edit",
      "Bash(ls -la *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
