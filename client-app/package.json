{
  "name": "nexa-app",
  "private": true,
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "react-native start",
    "bundle:android": "mkdir -p dist && npx react-native bundle --platform android --dev false --entry-file index.ts --bundle-output ./dist/index.android.bundle --assets-dest ./dist --minify true",
    "copy:android": "node ./scripts/copy-android-bundle.js",
    "build:android": "npm run bundle:android && npm run copy:android"
  },
  "dependencies": {
    "@ant-design/icons-react-native": "^2.3.2",
    "@ant-design/react-native": "^5.4.3",
    "dayjs": "^1.11.18",
    "decimal.js": "^10.6.0",
    "react": "18.2.0",
    "react-native": "0.75.3",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "3.15.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native/babel-preset": "0.75.3",
    "@react-native/metro-config": "^0.76.0",
    "@types/react": "^18.2.66",
    "@types/react-native": "^0.73.0",
    "babel-plugin-import": "^1.11.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.4.0"
  }
}
